generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("MINING_DATABASE_URL")
  directUrl = env("MINING_DATABASE_URL_DIRECT")
}

model MiningCandidate {
  id              String   @id @default(cuid())
  sourceUrl       String
  sourceId        String?
  sourceDomain    String?
  discoveredFromUrl String?
  canonicalUrl    String?
  fetchStatusCode Int?
  fetchContentType String?
  fetchedAt        DateTime?
  rawHash         String?
  parserType      String?
  discoveryMethod String?
  entityType      String?
  region          String?
  retryCount      Int      @default(0)
  lastError       String?
  html            String?
  extractedJson   Json?
  normalizedJson  Json?
  fingerprint     String?
  confidenceScore Float?
  dedupClusterId  String?
  status          String   @default("DISCOVERED")
  configVersion   Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  source          TrustedSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([sourceId])
  @@index([canonicalUrl])
  @@index([createdAt])
}

model ExportBatch {
  id              String   @id @default(cuid())
  externalBatchId String   @unique
  status          String
  configVersion   Int
  createdAt       DateTime @default(now())
}

model PipelineTelemetry {
  id            String   @id @default(cuid())
  stage         String
  status        String
  detail        String?
  candidateId   String?
  configVersion Int
  createdAt     DateTime @default(now())
}

model PipelineConfig {
  id         String   @id @default(cuid())
  version    Int      @unique
  isActive   Boolean  @default(false)
  payload    Json
  createdAt  DateTime @default(now())
}

model TrustedSource {
  id                    String   @id @default(cuid())
  name                  String
  domain                String
  seedUrl               String   @unique
  sourceType            String
  region                String
  trustTier             Int
  status                String   @default("ACTIVE")
  allowedPathPatterns   String[] @default([])
  blockedPathPatterns   String[] @default([])
  extractorType         String?
  crawlDepth            Int      @default(0)
  maxUrlsPerRun         Int      @default(1)
  lastDiscoveredAt      DateTime?
  lastSuccessAt         DateTime?
  lastFailureAt         DateTime?
  failureCount          Int      @default(0)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  candidates            MiningCandidate[]

  @@index([status])
  @@index([domain])
}
