{
  "name": "@artio/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run prisma:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint 'app/**/*.ts' 'lib/**/*.ts' 'components/**/*.ts' --max-warnings 50",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run prisma:generate",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:push": "DATABASE_URL=${DATABASE_URL:?DATABASE_URL is required for @artio/app prisma:push} DATABASE_URL_DIRECT=${DATABASE_URL_DIRECT:-$DATABASE_URL} prisma db push",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "create:admin": "node --import tsx scripts/create-admin.ts",
    "seed:permanent-admin": "node --import tsx scripts/seed-permanent-admin.ts",
    "bootstrap:prod-db": "node --import tsx scripts/bootstrap-production-db.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.33",
    "next-auth": "^4.24.11",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8",
    "@next-auth/prisma-adapter": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.16.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "tsx": "^4.20.6"
  }
}
