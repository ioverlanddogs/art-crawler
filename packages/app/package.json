    "zod": "^3.23.8",
    "bcryptjs": "^2.4.3",
    "@next-auth/prisma-adapter": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.16.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "@types/bcryptjs": "^2.4.6",
    "eslint": "^8.57.0",
