generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum UserRole {
  ADMIN
  REVIEWER
  ANALYST
}

enum CandidateStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(REVIEWER)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invitesSent   Invite[]  @relation("InviteSender")
  accounts      Account[]
  sessions      Session[]
}

model Invite {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  role       UserRole
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())
  senderId   String
  sender     User     @relation("InviteSender", fields: [senderId], references: [id])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PipelineConfigVersion {
  id          String   @id @default(cuid())
  version     Int      @unique
  isActive    Boolean  @default(false)
  configJson  Json
  createdAt   DateTime @default(now())
}

model ModelVersion {
  id             String   @id @default(cuid())
  name           String
  version        String
  coefficients   Json
  intercept      Float
  isActive       Boolean  @default(false)
  isShadow       Boolean  @default(false)
  promotedAt     DateTime?
  createdAt      DateTime @default(now())
}

model Candidate {
  id              String          @id @default(cuid())
  title           String
  sourceUrl       String
  sourcePlatform  String
  fingerprint     String          @unique
  configVersion   Int
  status          CandidateStatus @default(PENDING)
  confidenceScore Float           @default(0)
  dedupClusterId  String?
  importBatchId   String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  confidenceHistory ConfidenceHistory[]
}

model ConfidenceHistory {
  id            String   @id @default(cuid())
  candidateId   String
  modelVersionId String?
  score         Float
  signals       Json
  createdAt     DateTime @default(now())
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ImportBatch {
  id            String   @id @default(cuid())
  externalBatchId String @unique
  status        String
  createdAt     DateTime @default(now())
}

model PipelineTelemetry {
  id            String   @id @default(cuid())
  stage         String
  status        String
  detail        String?
  configVersion Int
  candidateId   String?
  createdAt     DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
