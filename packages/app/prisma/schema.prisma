generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum AdminRole {
  viewer
  moderator
  operator
  admin
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum PipelineConfigStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ModelVersionStatus {
  SHADOW
  ACTIVE
  ARCHIVED
}

enum ConfidenceBand {
  HIGH
  MEDIUM
  LOW
}

enum IngestExtractedStatus {
  PENDING
  APPROVED
  REJECTED
  DUPLICATE
}

enum DiscoveryStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum DiscoveryTemplateSource {
  manual
  ai_suggested
}

enum DiscoveryTemplateStatus {
  ACTIVE
  SUSPENDED
  CONVERGED
  ARCHIVED
}

enum DiscoverySuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EnrichmentRunStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum IngestionJobStatus {
  queued
  fetching
  extracting
  parsing
  matching
  needs_review
  approved
  publishing
  published
  failed
}

enum ProposedChangeSetStatus {
  draft
  in_review
  approved
  rejected
  merged
}

enum FieldDecision {
  accepted
  edited
  rejected
  uncertain
}

enum PublishStatus {
  unpublished
  ready
  blocked
  published
  rolled_back
}

enum DuplicateResolutionStatus {
  unresolved
  resolved_merge
  resolved_separate
  false_positive
  escalated
}

enum AssignmentSlaState {
  unassigned
  assigned
  in_progress
  overdue
  escalated
}

model AdminUser {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  role          AdminRole        @default(viewer)
  status        AdminUserStatus  @default(PENDING)
  passwordHash  String?
  lastLoginAt   DateTime?
  createdAt     DateTime         @default(now())
  createdById   String?
  createdBy     AdminUser?       @relation("AdminUserCreator", fields: [createdById], references: [id])
  createdUsers  AdminUser[]      @relation("AdminUserCreator")
  invites       AdminInvite[]
  accounts      Account[]
  sessions      Session[]
}

model AdminInvite {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PipelineConfigVersion {
  id           String               @id @default(cuid())
  region       String
  version      Int
  status       PipelineConfigStatus @default(DRAFT)
  configJson   Json
  changeReason String?
  activatedAt  DateTime?
  activatedBy  String?
  createdAt    DateTime             @default(now())
  createdBy    String?

  @@unique([region, version])
  @@index([region, status])
}

model ModelVersion {
  id            String             @id @default(cuid())
  entityType    String
  name          String
  version       String
  coefficients  Json
  intercept     Float
  status        ModelVersionStatus @default(SHADOW)
  promotedAt    DateTime?
  promotedBy    String?
  shadowMetrics Json?
  createdAt     DateTime           @default(now())

  @@index([entityType, status])
}

model Venue {
  id          String    @id @default(cuid())
  name        String
  slug        String?   @unique
  domain      String?   @unique
  timezone    String?
  region      String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  events      Event[]
  ingestRuns  IngestRun[]
  extractedEvents IngestExtractedEvent[]
}

model Artist {
  id          String    @id @default(cuid())
  name        String
  slug        String?   @unique
  bio         String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Artwork {
  id          String    @id @default(cuid())
  title       String
  slug        String?   @unique
  description String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Event {
  id                 String              @id @default(cuid())
  venueId            String?
  title              String
  startAt            DateTime
  endAt              DateTime?
  timezone           String?
  location           String?
  description        String?
  sourceUrl          String?
  publishStatus      PublishStatus       @default(unpublished)
  assignedReviewerId String?
  assignedAt         DateTime?
  escalationLevel    Int                  @default(0)
  dueAt              DateTime?
  slaState           AssignmentSlaState   @default(unassigned)
  publishedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  venue              Venue?              @relation(fields: [venueId], references: [id])
  proposedChangeSets ProposedChangeSet[]
  duplicateCandidates DuplicateCandidate[]
  versions           CanonicalRecordVersion[]
}

model SourceDocument {
  id            String   @id @default(cuid())
  sourceUrl     String
  sourceType    String?
  fetchedAt     DateTime?
  httpStatus    Int?
  fingerprint   String?
  rawHtml       String?
  extractedText String?
  metadataJson  Json?
  mediaJson     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ingestionJobs     IngestionJob[]
  ingestionLogs     IngestionLog[]
  extractionRuns    ExtractionRun[]
  proposedChangeSets ProposedChangeSet[]

  @@index([fingerprint])
  @@index([createdAt(sort: Desc)])
}

model IngestionJob {
  id                String             @id @default(cuid())
  sourceDocumentId  String
  requestedByUserId String?
  status            IngestionJobStatus @default(queued)
  startedAt         DateTime?
  completedAt       DateTime?
  errorCode         String?
  errorMessage      String?
  pipelineVersion   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  ingestionLogs  IngestionLog[]

  @@index([status, createdAt(sort: Desc)])
  @@index([sourceDocumentId])
}

model IngestionLog {
  id               String   @id @default(cuid())
  sourceDocumentId String
  ingestionJobId   String?
  stage            String
  status           String
  message          String
  detail           Json?
  createdAt        DateTime @default(now())

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  ingestionJob   IngestionJob?  @relation(fields: [ingestionJobId], references: [id], onDelete: SetNull)

  @@index([sourceDocumentId, createdAt(sort: Desc)])
  @@index([ingestionJobId, createdAt(sort: Desc)])
  @@index([stage, status])
}

model ExtractionRun {
  id                  String   @id @default(cuid())
  sourceDocumentId    String
  modelVersion        String?
  parserVersion       String?
  extractedFieldsJson Json?
  confidenceJson      Json?
  evidenceJson        Json?
  warningsJson        Json?
  createdAt           DateTime @default(now())

  sourceDocument     SourceDocument      @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  proposedChangeSets ProposedChangeSet[]
 
  @@index([sourceDocumentId, createdAt(sort: Desc)])
}

model ProposedChangeSet {
  id               String                  @id @default(cuid())
  sourceDocumentId String
  extractionRunId  String?
  matchedEventId   String?
  proposedDataJson Json?
  diffJson         Json?
  reviewStatus     ProposedChangeSetStatus @default(draft)
  reviewedByUserId String?
  reviewedAt       DateTime?
  notes            String?
  assignedReviewerId String?
  assignedAt       DateTime?
  escalationLevel  Int                     @default(0)
  dueAt            DateTime?
  slaState         AssignmentSlaState      @default(unassigned)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  extractionRun  ExtractionRun? @relation(fields: [extractionRunId], references: [id])
  matchedEvent   Event?         @relation(fields: [matchedEventId], references: [id])
  fieldReviews   FieldReview[]
  duplicateCandidates DuplicateCandidate[]

  @@index([reviewStatus, createdAt(sort: Desc)])
  @@index([sourceDocumentId])
}

model DuplicateCandidate {
  id                          String                    @id @default(cuid())
  proposedChangeSetId         String
  canonicalEventId            String?
  recordType                  String                    @default("Event")
  source                      String?
  matchConfidence             Float                     @default(0)
  corroborationSourceCount    Int                       @default(0)
  corroborationConfidence     Float                     @default(0)
  conflictingSourceCount      Int                       @default(0)
  unresolvedBlockerCount      Int                       @default(0)
  fieldCorroborationJson      Json?
  confidenceExplanation       String?
  duplicateRiskExplanation    String?
  reviewerNote                String?
  assignedReviewerId          String?
  assignedAt                  DateTime?
  escalationLevel             Int                       @default(0)
  dueAt                       DateTime?
  slaState                    AssignmentSlaState        @default(unassigned)
  resolutionStatus            DuplicateResolutionStatus @default(unresolved)
  resolvedByUserId            String?
  resolvedAt                  DateTime?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt

  proposedChangeSet ProposedChangeSet @relation(fields: [proposedChangeSetId], references: [id], onDelete: Cascade)
  canonicalEvent    Event?            @relation(fields: [canonicalEventId], references: [id])

  @@index([resolutionStatus, updatedAt(sort: Desc)])
  @@index([proposedChangeSetId, resolutionStatus])
  @@index([canonicalEventId])
}

model FieldReview {
  id                  String        @id @default(cuid())
  proposedChangeSetId String
  fieldPath           String
  proposedValueJson   Json?
  canonicalValueJson  Json?
  confidence          Float?
  evidenceRefsJson    Json?
  decision            FieldDecision?
  reviewerId          String?
  reviewerComment     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  proposedChangeSet ProposedChangeSet @relation(fields: [proposedChangeSetId], references: [id], onDelete: Cascade)

  @@index([proposedChangeSetId])
  @@unique([proposedChangeSetId, fieldPath])
}

model PublishBatch {
  id              String   @id @default(cuid())
  createdByUserId String?
  status          String   @default("pending")
  eventIdsJson    Json
  releaseSummary  String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model CanonicalRecordVersion {
  id                  String   @id @default(cuid())
  eventId             String
  versionNumber       Int
  dataJson            Json
  changeSummary       String?
  sourceDocumentId    String?
  proposedChangeSetId String?
  publishBatchId      String?
  createdByUserId     String?
  createdAt           DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, versionNumber])
  @@index([eventId, createdAt(sort: Desc)])
}

model IngestExtractedEvent {
  id                          String                @id @default(cuid())
  region                      String?
  configVersion               Int?
  venueId                     String?
  title                       String
  startAt                     DateTime
  endAt                       DateTime?
  timezone                    String?
  locationText                String?
  description                 String?
  artistNames                 String[]
  imageUrl                    String?
  sourceUrl                   String?
  confidenceScore             Int
  confidenceBand              ConfidenceBand
  confidenceReasons           Json?
  fingerprint                 String                @unique
  clusterKey                  String?
  duplicateOfId               String?
  source                      String
  status                      IngestExtractedStatus @default(PENDING)
  moderatedBy                 String?
  moderatedAt                 DateTime?
  rejectionReason             String?
  autoApproved                Boolean               @default(false)
  autoApprovedAt              DateTime?
  miningConfidenceScore       Int?
  miningObservationCount      Int?
  miningCrossSourceCount      Int?
  importBatchId               String?
  artioEventId                String?
  ingestRunId                 String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  venue                       Venue?                @relation(fields: [venueId], references: [id])
  importBatch                 ImportBatch?          @relation(fields: [importBatchId], references: [id])
  ingestRun                   IngestRun?            @relation(fields: [ingestRunId], references: [id])
  duplicateOf                 IngestExtractedEvent? @relation("EventDuplicates", fields: [duplicateOfId], references: [id])
  duplicates                  IngestExtractedEvent[]@relation("EventDuplicates")

  @@index([fingerprint])
  @@index([region, status])
  @@index([clusterKey])
  @@index([confidenceBand, status, createdAt(sort: Desc)])
  @@index([importBatchId])
}

model IngestExtractedArtist {
  id                    String                @id @default(cuid())
  name                  String
  sourceUrl             String?
  confidenceScore       Int
  confidenceBand        ConfidenceBand
  confidenceReasons     Json?
  fingerprint           String                @unique
  clusterKey            String?
  duplicateOfId         String?
  source                String
  status                IngestExtractedStatus @default(PENDING)
  moderatedBy           String?
  moderatedAt           DateTime?
  rejectionReason       String?
  autoApproved          Boolean               @default(false)
  autoApprovedAt        DateTime?
  importBatchId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([fingerprint])
  @@index([status, createdAt(sort: Desc)])
}

model IngestExtractedArtwork {
  id                    String                @id @default(cuid())
  title                 String
  artistName            String?
  sourceUrl             String?
  confidenceScore       Int
  confidenceBand        ConfidenceBand
  confidenceReasons     Json?
  fingerprint           String                @unique
  clusterKey            String?
  duplicateOfId         String?
  source                String
  status                IngestExtractedStatus @default(PENDING)
  moderatedBy           String?
  moderatedAt           DateTime?
  rejectionReason       String?
  autoApproved          Boolean               @default(false)
  autoApprovedAt        DateTime?
  importBatchId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([fingerprint])
  @@index([status, createdAt(sort: Desc)])
}

model ImportBatch {
  id                 String               @id @default(cuid())
  externalBatchId    String               @unique
  source             String
  region             String
  status             String
  importedCount      Int                  @default(0)
  skippedCount       Int                  @default(0)
  errorCount         Int                  @default(0)
  feedbackReceivedAt DateTime?
  createdAt          DateTime             @default(now())
  events             IngestExtractedEvent[]

  @@index([region, createdAt(sort: Desc)])
}

model IngestRun {
  id              String    @id @default(cuid())
  venueId         String?
  startedAt       DateTime
  completedAt     DateTime?
  fetchStatusCode Int?
  extractMethod   String?
  tokenCostUsd    Float?
  provider        String?
  status          String
  errorMessage    String?
  createdAt       DateTime  @default(now())
  venue           Venue?    @relation(fields: [venueId], references: [id])
  events          IngestExtractedEvent[]

  @@index([createdAt(sort: Desc)])
}

model PipelineTelemetry {
  id            String   @id @default(cuid())
  stage         String
  status        String
  detail        String?
  configVersion Int?
  entityId      String?
  entityType    String?
  pipelineRunId String?
  durationMs    Int?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([stage, createdAt(sort: Desc)])
  @@index([pipelineRunId, createdAt])
}

model VenueProfile {
  id              String          @id @default(cuid())
  domain          String          @unique
  name            String?
  eventsPageUrl   String?
  region          String
  platformType    String?
  requiresJs      Boolean         @default(false)
  ingestFrequency String?
  lastCrawledAt   DateTime?
  candidateYield  Int             @default(0)
  approvalRate    Float           @default(0)
  status          DiscoveryStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model DiscoveryTemplate {
  id         String                  @id @default(cuid())
  region     String
  template   String
  source     DiscoveryTemplateSource
  status     DiscoveryTemplateStatus @default(ACTIVE)
  alpha      Float                   @default(1)
  beta       Float                   @default(1)
  totalJobs  Int                     @default(0)
  lastYieldAt DateTime?
  createdAt  DateTime                @default(now())

  @@index([region, status])
}

model DiscoveryGoal {
  id        String   @id @default(cuid())
  region    String   @unique
  target    Int
  deadline  DateTime?
  createdAt DateTime @default(now())
}

model DiscoverySuggestion {
  id           String                    @id @default(cuid())
  region       String
  template     String
  reason       String?
  status       DiscoverySuggestionStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  rejectReason String?
  createdAt    DateTime                  @default(now())

  @@index([region, status])
}

model EnrichmentRun {
  id               String              @id @default(cuid())
  entityType       String
  entityId         String
  template         String
  status           EnrichmentRunStatus
  fieldsChanged    String[]
  confidenceBefore Int?
  confidenceAfter  Int?
  sourceUrl        String?
  metadata         Json?
  createdAt        DateTime            @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String    @id @default(cuid())
  sessionToken String    @unique
  userId       String
  expires      DateTime
  user         AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
