DATABASE_URL=postgresql://postgres:postgres@localhost:5432/artio_app?schema=public
# For local/dev/CI, this can be the same as DATABASE_URL.
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/artio_app?schema=public
MINING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/artio_mining?schema=public
MINING_DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/artio_mining?schema=public
# Optional in local dev. Defaults to redis://localhost:6379 when unset.
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=change-me # MUST be replaced with a strong unique secret before any deployment.
# Bootstrap admin credentials. Set before running seed:permanent-admin or create:admin.
# Email must match an ACTIVE AdminUser row. Password is hashed with bcrypt cost 12.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-before-use
NEXTAUTH_URL=http://localhost:3000
# Canonical shared secret for mining -> app import authentication.
MINING_IMPORT_SECRET=dev-mining-secret
# Legacy fallback (deprecated): MINING_SERVICE_SECRET
PIPELINE_IMPORT_URL=http://localhost:3000/api/pipeline/import
# Optional runtime toggles.
# RUN_ONCE=true
# MINING_HEALTH_PORT=7301
# E2E_BASE_URL=http://localhost:3000

# AI extraction — required for real field extraction in the admin intake pipeline.
# If unset, extraction runs in stub mode with placeholder values.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth — required for login. Create credentials at console.cloud.google.com.
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google sign-in button is always shown on the login page when GOOGLE_CLIENT_ID is configured.
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED is no longer used and can be removed from Vercel env vars.
